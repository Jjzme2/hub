# In Vercel: add each variable under Project → Settings → Environment Variables.
# Vercel automatically maps NUXT_* names to Nuxt runtimeConfig.

# ─── Firebase ──────────────────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your apps → Web app
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Service account JSON for Firebase Admin SDK (server-side only)
# In Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON as a single-line string (or base64-encode it)
FIREBASE_SERVICE_ACCOUNT=

# ─── Cloudflare R2 ─────────────────────────────────────────────────────────────
# Create bucket: Cloudflare Dashboard → R2 → Create bucket
# API keys: R2 → Manage R2 API Tokens → Create API token (Object Read & Write)
NUXT_R2_ACCOUNT_ID=
NUXT_R2_ACCESS_KEY_ID=
NUXT_R2_SECRET_ACCESS_KEY=
NUXT_R2_BUCKET_NAME=
# S3-compatible endpoint — format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
NUXT_R2_ENDPOINT=

# Optional: custom public domain for R2 bucket (Cloudflare R2 → bucket → Settings → Custom Domains)
# Leave blank to use presigned URLs for all reads
NUXT_PUBLIC_R2_PUBLIC_URL=

# ─── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated emails that receive the 'admin' role on first registration
ADMIN_EMAILS=

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 3 000 emails/month
NUXT_RESEND_API_KEY=
# Must be a verified sender domain in Resend (e.g. noreply@yourdomain.com)
NUXT_RESEND_FROM=
